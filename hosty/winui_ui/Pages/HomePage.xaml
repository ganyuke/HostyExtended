<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="winui_ui.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:winui_ui.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" MaxWidth="400">
            <FontIcon Glyph="&#xE756;" FontSize="64" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Welcome to Hosty" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" TextAlignment="Center" />
            <TextBlock Text="Hosty makes it incredibly easy to manage, run, and share your Fabric Minecraft servers." 
                       Style="{StaticResource BodyTextBlockStyle}" 
                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
            
            <Button x:Name="CreateServerButton" Content="Create your first server" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Center" Margin="0,24,0,0" />
        </StackPanel>
    </Grid>
</Page>
